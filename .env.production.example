DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

DATABASE_URL=postgres://cited:replace-me@db:5432/cited_knowledge_desk
REDIS_URL=redis://redis:6379/0

POSTGRES_DB=cited_knowledge_desk
POSTGRES_USER=cited
POSTGRES_PASSWORD=replace-me

MAX_DOCUMENT_UPLOAD_SIZE=10485760
DOCUMENT_INGESTION_AUTO_QUEUE=True
DOCUMENT_CHUNK_TARGET_TOKENS=800
DOCUMENT_CHUNK_OVERLAP_TOKENS=120

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=replace-me

LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_MAX_OUTPUT_TOKENS=700
